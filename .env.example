# =============================================================================
# jarvis-notifications — Push notification service (self-hosted)
# =============================================================================
# Port: 7712
# Run: ./run.sh or ./run.sh --docker

# ── SERVER ──────────────────────────────────────────────────────────────────
NOTIFICATIONS_PORT=7712

# ── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:postgres@host.docker.internal:5432/jarvis_notifications
MIGRATIONS_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/jarvis_notifications

# ── AUTHENTICATION ──────────────────────────────────────────────────────────
JARVIS_APP_ID=jarvis-notifications
JARVIS_APP_KEY=__SET_ME__
# Gates the admin API. The service refuses to start if this is empty or
# left as the literal placeholder below — set a real, random secret.
ADMIN_API_KEY=__SET_ME__

# ── JWT (for validating mobile user tokens — must match jarvis-auth) ───────
# Must match AUTH_SECRET_KEY in jarvis-auth and every service that validates
# JWTs. The service refuses to start if this is empty or the placeholder.
AUTH_SECRET_KEY=__SET_ME__
AUTH_ALGORITHM=HS256

# ── SERVICE DISCOVERY ───────────────────────────────────────────────────────
JARVIS_CONFIG_URL=http://localhost:7700
JARVIS_AUTH_BASE_URL=http://localhost:7701

# ── LOGGING (via jarvis-log-client) ─────────────────────────────────────────
JARVIS_LOG_CONSOLE_LEVEL=INFO
JARVIS_LOG_REMOTE_LEVEL=INFO

# ── RELAY (optional — omit for no push delivery) ───────────────────────────
# RELAY_URL=https://relay.jarvisautomation.io
# RELAY_HOUSEHOLD_JWT=eyJhbG...

# ── CLEANUP ─────────────────────────────────────────────────────────────────
NOTIFICATION_LOG_RETENTION_DAYS=30
TOKEN_CLEANUP_INTERVAL_HOURS=24
